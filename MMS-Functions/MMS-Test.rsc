        :put "|   |   |/    |    \\ /    |/    | /  _|   |   | /  _|    \\|      |    "
        :put "| _   _ |  o  |  _  |  o  |   __|/  [_| _   _ |/  [_|  _  |      |    "
        :put "|  \\_/  |     |  |  |     |  |  |    _|  \\_/  |    _|  |  |_|  |_|    "
